{
  "name": "brasalino-crm-pdv",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "analyze": "vite build --mode analyze",
    "migrate-imports": "node scripts/migrate-imports.js",
    "postmigrate": "npm run build",
    "test": "vitest",
    "test:unit": "vitest --exclude '**/integration/**'",
    "test:integration": "cross-env VITE_USE_TEST_RPC=true vitest src/__tests__/integration",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage --coverage.reporter=text --coverage.reporter=html"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.185.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/query-sync-storage-persister": "^5.99.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-persist-client": "^5.99.0",
    "@tanstack/react-virtual": "^3.13.23",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.5.1",
    "dompurify": "^3.4.0",
    "lucide-react": "^1.8.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "supabase": "^2.91.1",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.5"
  }
}
