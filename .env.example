# ================================================
# EXEMPLO DE CONFIGURAÇÃO - CRM/PDV
# ================================================
# Copie este arquivo para .env.local e preencha com seus valores reais
# NUNCA coloque valores reais neste arquivo!

# Supabase Configuration
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_sua_chave_anonima_aqui

# Storage Local
VITE_STORAGE_SECRET=uma_frase_secreta_aleatoria_aqui

# Feature Flags
VITE_ENABLE_PIX=true
VITE_ENABLE_WHATSAPP=false
VITE_ENABLE_NOTIFICATIONS=true

# API Configuration
VITE_API_URL=http://localhost:5173
VITE_API_TIMEOUT=30000

# Debug (desenvolvimento)
VITE_ENABLE_LOGS=true
VITE_DEBUG_MODE=false